@charset "utf-8";

.grdtbtncenter { display: flex; position: relative; justify-content: center=
; }

.grdtbtncenter .btncntr { width: 260px; border-radius: 32px; text-align: ce=
nter; margin: 5px 0px; z-index: 1; background-color: rgb(51, 51, 51); }

.smdgrdt { width: 100%; height: 100px; pointer-events: none; position: abso=
lute; bottom: 0px; }

.rsbctr { position: absolute; display: block; visibility: hidden; z-index: =
1; }

#mainImageContainer:hover .rsbctr, .rsbctr:hover { visibility: visible; }

.rsbctr .icon::before, .rsbctr:hover .icon::before { font-family: BingMMIco=
ns; vertical-align: middle; display: inline-block; }

.rsbctr:hover .icon::before { content: "=EE=AF=A6"; line-height: 12px; font=
-size: 16px; width: 12px; height: 12px; }

.rsbctr .fav > span.icon::before, .rsbctr:hover .fav > span.icon::before { =
content: "=EE=A3=91"; line-height: 16px; font-size: 20px; width: 16px; heig=
ht: 16px; }

.rsb { cursor: pointer; border: 0px; padding: 8px 12px; border-radius: 16px=
; background-color: rgba(17, 17, 17, 0.8); font-family: Arial; font-weight:=
 400; color: rgb(255, 255, 255); }

.rsb:hover { background-color: rgb(17, 17, 17); }

.rsb .fav img { width: 16px; height: 16px; display: inline-block; vertical-=
align: middle; }

.rsb .text { max-width: 150px; text-overflow: ellipsis; margin-inline-start=
: 8px; display: inline-block; overflow: hidden; vertical-align: middle; }

.rsb:hover .text { margin-inline-end: 8px; }

.rsb.mini .text { display: none; }

.rsb:hover.mini .text { display: inline-block; }

#detailMeta.mfi #imagemeta #src::before { content: none; height: 0px; width=
: 0px; display: none; }

#detailMeta #imagemeta #src::before, #detailMeta.mfi .mfvi, .pi .domain img=
, #pagesIncl .iscscd_data .domain:not(.dic)::before { width: 12px; height: =
12px; vertical-align: middle; margin-right: 8px; border-radius: 2px; }

#detailMeta.mfi .mfvi { display: inline-block; margin-top: -1px; margin-lef=
t: -20px; }

#detailMeta #imagemeta #src { padding-left: 20px; }

#detailMeta #imagemeta #src::before { margin-left: -20px; }

.dpfi { display: inline-block; vertical-align: middle; margin-right: 4px; h=
eight: 12px; width: 12px; border-radius: 2px; }

.fi { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width=
: calc(100% + 12px); }

.no::before { content: "=EE=A3=90"; font-family: BingMMIcons; color: rgb(10=
2, 102, 102); line-height: 13px; font-size: 15px; height: 12px; width: 12px=
; margin-right: 4px; display: inline-block; vertical-align: middle; }

html[dir=3D"rtl"] .no::before { direction: ltr; }

.fi > * { display: inline-block; vertical-align: middle; }

.richImage .dpfi { vertical-align: middle; }

.vs_preview .richImage.relProd .dpfi { margin-right: 4px; width: 12px; heig=
ht: 12px; position: relative; }

.vs_container .richImage .captionContainer span.domain { color: rgb(118, 11=
8, 118); }

body #b_header .mic_cont.partner .b_icon.shtip::before { bottom: -15px; lef=
t: 12px; position: absolute; background-color: rgb(102, 102, 102); width: 1=
2px; height: 12px; content: ""; transform: rotate(45deg); z-index: 6; }

body #b_header .mic_cont.partner .b_icon.shtip::after { top: 49px; left: 18=
px; position: absolute; background-color: rgb(102, 102, 102); content: attr=
(data-sbtipx); font: 13px / 18px Arial, Helvetica, sans-serif; white-space:=
 nowrap; color: rgb(255, 255, 255); padding: 10px 15px; border-radius: 4px;=
 z-index: 4; transform: translateX(-50%); }

[data-tooltip] { position: relative; }

[vptest]::after, [data-tooltip]:not(.disableTooltip):hover::after, [data-to=
oltip].shtip:not(.disableTooltip)::after { position: absolute; left: 50%; b=
ackground-color: rgb(34, 34, 34); content: attr(data-tooltip); font: 13px A=
rial; white-space: nowrap; color: rgb(255, 255, 255); padding: 10px 15px; t=
op: -40px; transform: translateX(-50%); z-index: 4; }

[vptest]::before, [data-tooltip]:not(.disableTooltip):hover::before, [data-=
tooltip].shtip:not(.disableTooltip)::before { position: absolute; left: 50%=
; background-color: rgb(34, 34, 34); width: 19px; height: 19px; content: ""=
