left: -30px; z-index: 1; border-radius: 50%; border-width: 1.5px; border-st=
yle: solid; border-image: initial; border-color: rgb(0, 120, 212) rgb(199, =
224, 244) rgb(199, 224, 244); animation: 1.3s cubic-bezier(0.53, 0.21, 0.29=
, 0.67) 0s infinite normal none running spin360Deg; }

#rewardsLoadingAnimation.extraLarge { width: 100px; height: 100px; }

#rewardsLoadingAnimation.large { width: 80px; height: 80px; }

#rewardsLoadingAnimation.medium { width: 60px; height: 60px; }

#rewardsLoadingAnimation.small { width: 40px; height: 40px; }

#rewardsLoadingAnimation.extraSmall { width: 20px; height: 20px; }

@keyframes spin360Deg {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
