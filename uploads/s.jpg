x; height: 100vh; z-index: 1100; box-shadow: rgba(0, 0, 0, 0.05) 0px 0px 0p=
x 1px, rgba(0, 0, 0, 0.1) 0px 0px 0px 2px; }

#rewardsPanelContainer.darkMode { background: rgb(17, 16, 15); color: rgb(2=
37, 235, 233); }

#rewardsPanelContainer.b_hide { display: none; }

#rewardsPanelContainer #panelFlyout { width: 102%; height: 100%; border: 0p=
x; }

#rewardsPanelContainer #panelHeader { background: rgb(255, 255, 255); paddi=
ng: 15px; display: none; text-align: center; justify-content: space-between=
; border-bottom: 1px solid rgb(204, 204, 204); }

#rewardsPanelContainer #panelHeader .title { font-weight: 500; font-size: 2=
0px; line-height: 22px; display: flex; align-items: center; }

#rewardsPanelContainer #closeRewardsPanel { position: absolute; right: 15px=
; width: 12px; height: 12px; padding: 8px; top: 13px; }

#rewardsPanelContainer #closeRewardsPanel:hover, #rewardsPanelContainer #cl=
oseRewardsPanel:focus { cursor: pointer; }
